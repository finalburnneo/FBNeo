# IGS PGM2 drivers - self-describing driver group fragment.
# Sets group_desc/group_use/group_drivers/group_srcs (data only, no targets).
# Add a driver: drop d_<name>.cpp here and add one line to group_drivers.

group_desc    = 'IGS PGM2 drivers'
group_use     = [
    'arm9',
    'eeprom',
    'i2ceeprom',
    'ics2115',
    'ymz770',
]
group_drivers = [
    'd_pgm2.cpp',
]
group_srcs    = [
    'pgm2_crypt.cpp',
    'pgm2_draw.cpp',
    'pgm2_run.cpp',
]
