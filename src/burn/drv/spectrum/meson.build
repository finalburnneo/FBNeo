# ZX Spectrum drivers - self-describing driver group fragment.
# Sets group_desc/group_use/group_drivers/group_srcs (data only, no targets).
# Add a driver: drop d_<name>.cpp here and add one line to group_drivers.

group_desc    = 'ZX Spectrum drivers'
group_use     = [
    'z80',
    'ay8910',
    'beep',
]
group_drivers = [
    'd_spectrum.cpp',
]
group_srcs    = [
    'spectrum.cpp',
]
